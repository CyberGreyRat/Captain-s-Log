{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Captain's Log CLI - Debug (TDM-GCC)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/../.venv/Scripts/ninja.exe",
        "CMAKE_CXX_COMPILER": "C:/TDM-GCC-64/bin/g++.exe",
        "CAPCOM_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Captain's Log CLI - Release (TDM-GCC)",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release", "CAPCOM_BUILD_TESTS": "OFF" }
    }
  ],
  "buildPresets": [
    { "name": "default", "configurePreset": "default" },
    { "name": "release", "configurePreset": "release" }
  ]
}


